        "type": "number",
        "rules": { "range": [18, 95] },
        "q": {
          "en": "What is your age?",
          "hi": "आपकी आयु क्या है?",
          "ta": "உங்கள் வயது என்ன?"
        }
      },
      {
        "id": "occupation",
        "type": "choice",
        "codeType": "NCO",
        "options": ["Salaried", "Self-employed", "Farmer", "Unemployed", "Student"],
        "q": {
          "en": "What is your occupation?",
          "hi": "आपका व्यवसाय क्या है?",
          "ta": "உங்கள் தொழில் என்ன?"
        }
      },
      { "id": "_branch", "type": "adaptive" },
      {
        "id": "income",
        "type": "number",
        "codeType": null,
        "rules": {
          "crossField": { "ifOccupation": "Unemployed", "max": 50000 },
          "contextRef": "income"
        },
        "q": {
          "en": "Monthly income (₹)?",
          "hi": "मासिक आय (₹)?",
          "ta": "மாதாந்திர வருமானம் (₹)?"
        }
      },
      {
        "id": "household",
        "type": "number",
        "rules": { "range": [1, 30] },
        "q": {
          "en": "Household size?",
          "hi": "परिवार का आकार?",
          "ta": "குடும்ப அளவு?"
        }
      }
    ],
