{
  "title": "MoSPI Survey Guidelines and Standards",
  "version": "2024.1",
  "domains": {
    "labour": {
      "description": "Employment, unemployment, and labour force statistics",
      "key_indicators": [
        "Employment status",
        "Occupation classification (NCO)",
        "Industry classification (NIC)",
        "Working hours",
        "Wages and earnings",
        "Job satisfaction"
      ],
      "mandatory_questions": [
        "age",
        "gender",
        "education",
        "employment_status"
      ],
      "coding_standards": {
        "occupation": "NCO-2015",
        "industry": "NIC-2008",
        "education": "ISCED-2011"
      }
    },
    "health": {
      "description": "Health status, healthcare access, and health outcomes",
      "key_indicators": [
        "Health status",
        "Healthcare utilization",
        "Health insurance coverage",
        "Maternal and child health",
        "Chronic conditions",
        "Healthcare satisfaction"
      ],
      "mandatory_questions": [
        "age",
        "gender",
        "location",
        "health_status"
      ],
      "coding_standards": {
        "diseases": "ICD-10",
        "procedures": "ICD-10-PCS"
      }
    },
    "education": {
      "description": "Educational attainment, literacy, and learning outcomes",
      "key_indicators": [
        "Literacy status",
        "Educational attainment",
        "School enrollment",
        "Educational expenditure",
        "Skills and competencies"
      ],
      "mandatory_questions": [
        "age",
        "gender",
        "literacy_status",
        "education_level"
      ],
      "coding_standards": {
        "education": "ISCED-2011"
      }
    },
    "agriculture": {
      "description": "Agricultural practices, crop production, and rural livelihoods",
      "key_indicators": [
        "Land ownership",
        "Crop production",
        "Livestock",
        "Agricultural income",
        "Irrigation methods",
        "Technology adoption"
      ],
      "mandatory_questions": [
        "age",
        "gender",
        "land_ownership",
        "primary_crop"
      ],
      "coding_standards": {
        "crops": "FAO-Crop-Classification"
      }
    },
    "household": {
      "description": "Household characteristics, consumption, and living standards",
      "key_indicators": [
        "Household size",
        "Housing conditions",
        "Asset ownership",
        "Consumption expenditure",
        "Income sources",
        "Social group"
      ],
      "mandatory_questions": [
        "household_size",
        "location",
        "social_group",
        "income_source"
      ],
      "coding_standards": {
        "consumption": "COICOP-2018"
      }
    },
    "enterprise": {
      "description": "Business establishments, industrial production, and economic activity",
      "key_indicators": [
        "Enterprise type",
        "Employment size",
        "Production value",
        "Technology usage",
        "Market access",
        "Financial access"
      ],
      "mandatory_questions": [
        "enterprise_type",
        "industry",
        "employment_size",
        "annual_turnover"
      ],
      "coding_standards": {
        "industry": "NIC-2008",
        "enterprise_size": "MSME-Classification"
      }
    }
  },
  "question_guidelines": {
    "demographic_questions": {
      "order": 1,
      "description": "Basic demographic information should be collected first",
      "required_fields": ["age", "gender", "location"],
      "optional_fields": ["marital_status", "religion", "social_group", "education"]
    },
    "core_questions": {
      "order": 2,
      "description": "Main survey questions related to the domain",
      "guidelines": [
        "Use clear, simple language",
        "Avoid leading questions",
        "Ensure cultural sensitivity",
        "Include standard classifications where applicable"
      ]
    },
    "sensitive_questions": {
      "order": 3,
      "description": "Income, personal, or sensitive topics",
      "guidelines": [
        "Place towards the end of survey",
        "Provide 'prefer not to answer' options",
        "Ensure confidentiality assurance",
        "Use appropriate validation ranges"
      ]
    },
    "follow_up_questions": {
      "order": 4,
      "description": "Additional details or clarifications",
      "guidelines": [
        "Use conditional logic",
        "Keep optional where possible",
        "Ensure relevance to previous answers"
      ]
    }
  },
  "validation_rules": {
    "age": {
      "type": "number",
      "min": 0,
      "max": 120,
      "required": true
    },
    "income": {
      "type": "number",
      "min": 0,
      "max": 10000000,
      "required": false,
      "sensitivity": "high"
    },
    "household_size": {
      "type": "number",
      "min": 1,
      "max": 50,
      "required": true
    },
    "working_hours": {
      "type": "number",
      "min": 0,
      "max": 168,
      "required": false
    }
  },
  "language_guidelines": {
    "primary_language": "en",
    "supported_languages": ["hi", "bn", "te", "ta", "mr", "gu", "kn", "ml", "or"],
    "translation_requirements": [
      "Maintain meaning accuracy",
      "Use culturally appropriate terms",
      "Ensure readability for target audience",
      "Include regional variations where needed"
    ]
  },
  "deployment_standards": {
    "channels": ["web", "mobile_app", "whatsapp", "ivr", "paper"],
    "mobile_requirements": [
      "Responsive design",
      "Touch-friendly interface",
      "Offline capability (optional)",
      "Low bandwidth optimization"
    ],
    "accessibility": [
      "Screen reader compatibility",
      "High contrast mode",
      "Large text options",
      "Voice input support"
    ]
  },
  "quality_assurance": {
    "pre_deployment_checks": [
      "Question clarity review",
      "Translation accuracy check",
      "Logic flow validation",
      "Mobile compatibility test",
      "Accessibility compliance"
    ],
    "pilot_testing": [
      "Small sample test (n=20-50)",
      "Feedback collection",
      "Response time measurement",
      "Error rate analysis"
    ]
  }
}